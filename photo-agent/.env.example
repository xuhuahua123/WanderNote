# WanderNote Photo Agent 环境变量配置
#
# 使用方法：
# 1. 复制此文件为 .env（基础配置）
# 2. 复制为 .env.dev（开发环境）或 .env.prod（生产环境）
# 3. 填写真实的配置值
# 4. .env 文件不会被提交到代码仓库
#
# 环境切换：
#   设置环境变量 AGENT_ENV=dev 或 AGENT_ENV=prod
#   会自动加载对应的 .env.{env} 文件
#
# 配置优先级：环境变量 > .env.{AGENT_ENV} > .env > config.yaml > 默认值

# Agent 唯一标识
AGENT_ID=

# 后端服务器地址
SERVER_URL=

# Agent 认证 token（优先于 config.yaml 中的配置）
AGENT_TOKEN=

# 照片根目录
PHOTO_ROOT=

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 扫描间隔（分钟）
SCAN_INTERVAL_MINUTES=10

# 缩略图长边尺寸（像素）
THUMB_LONG_EDGE=360

# 预览图长边尺寸（像素）
PREVIEW_LONG_EDGE=1280

# 索引上传批量大小
INDEX_BATCH_SIZE=100

# 缩略图上传并发数
THUMB_UPLOAD_CONCURRENCY=3

# 预览图上传并发数
PREVIEW_UPLOAD_CONCURRENCY=1
